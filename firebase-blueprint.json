{
  "entities": {
    "Tournament": {
      "title": "Tournament Settings",
      "description": "Configuration the organizer sets for the tournament.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "format": { "type": "string", "enum": ["2s", "4s"] },
        "totalRounds": { "type": "integer" },
        "currentRound": { "type": "integer" },
        "status": { "type": "string", "enum": ["configuring", "active", "completed"] },
        "maxCourts": { "type": "integer" },
        "playMode": { "type": "string", "enum": ["matches", "individual"] },
        "splitWomenEvenly": { "type": "boolean" },
        "tournamentType": { "type": "string", "enum": ["scramble", "fixed_teams"] },
        "matchingStyle": { "type": "string", "enum": ["random_pool_play", "set_pools_round_robin"] },
        "numPools": { "type": "integer" }
      },
      "required": ["format", "totalRounds", "currentRound", "status"]
    },
    "Player": {
      "title": "Player",
      "description": "A player participating in the tournament.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "points": { "type": "integer" },
        "byesCount": { "type": "integer" },
        "satOutRounds": { "type": "array" },
        "gender": { "type": "string" },
        "pool": { "type": "string" }
      },
      "required": ["id", "name", "points", "byesCount"]
    },
    "Match": {
      "title": "Match",
      "description": "A match played in the tournament.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "round": { "type": "integer" },
        "court": { "type": "integer" },
        "teamNumber": { "type": "integer" },
        "teamA": { "type": "array" },
        "teamB": { "type": "array" },
        "teamAScore": { "type": "integer" },
        "teamBScore": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "completed"] }
      },
      "required": ["id", "round", "teamA", "status"]
    },
    "Round": {
      "title": "Round Info",
      "description": "Metadata for a specific round, like who has a bye.",
      "type": "object",
      "properties": {
        "roundNumber": { "type": "integer" },
        "byes": { "type": "array" }
      },
      "required": ["roundNumber", "byes"]
    },
    "Organizer": {
      "title": "Organizer",
      "description": "An organizer table to allow multiple users to manage tournaments.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string" },
        "addedBy": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "organizers/{organizerId}": {
      "schema": "Organizer",
      "description": "Registered organizers."
    },
    "tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Tournament configuration."
    },
    "tournaments/{tournamentId}/players/{playerId}": {
      "schema": "Player",
      "description": "Participant in the specific tournament."
    },
    "tournaments/{tournamentId}/matches/{matchId}": {
      "schema": "Match",
      "description": "Individual matches within the specific tournament."
    },
    "tournaments/{tournamentId}/rounds/{roundId}": {
      "schema": "Round",
      "description": "Round information for the specific tournament."
    }
  }
}
